# API Configuration
# Backend API URL - Update this based on your environment

# For Development (local backend)
VITE_API_URL=http://localhost:4000/api

# For Production (replace with your actual API URL)
# VITE_API_URL=https://api.your-domain.com/api
# VITE_API_URL=https://flowdeploy.cloud/api

# Razorpay Configuration
# Get these from https://dashboard.razorpay.com/

# For Testing
# VITE_RAZORPAY_KEY_ID=rzp_test_your_test_key_id

# For Production
VITE_RAZORPAY_KEY_ID=rzp_live_your_live_key_id